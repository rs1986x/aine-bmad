# Copy to .env and fill in real values for local development.
# Only this example file is committed; .env / .env.test are git-ignored.

# Node runtime environment: development | test | production
NODE_ENV=development

# Port the backend Express server listens on
PORT=8080

# Postgres connection string used by the backend
DATABASE_URL=postgres://todo:todo@localhost:5432/todo

# Allowed CORS origin for the frontend.
# This is the local Vite-dev value (frontend served by `vite` on :5173).
# The Docker Compose stack instead uses http://localhost:8080 (set inline in
# docker-compose.yml), since the browser's origin there is the nginx port.
CORS_ORIGIN=http://localhost:5173
